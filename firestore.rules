rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: comments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - comment: string (required, 1-500 chars)
    //   - rating: number (required, 1-5)
    //   - image: string (optional, < 1MB base64)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "shansarkarbhai@gmail.com" ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'email', 'role', 'createdAt'];
      let requiredFields = ['uid', 'email', 'role', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'client'] &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if isAdmin();
      allow delete: if false;
    }

    function isValidComment(data) {
      let allowedFields = ['name', 'comment', 'rating', 'createdAt', 'image'];
      let requiredFields = ['name', 'comment', 'rating', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.comment is string && data.comment.size() >= 1 && data.comment.size() <= 1000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt is timestamp &&
             (!('image' in data) || (data.image == null || (data.image is string && data.image.size() < 1048576)));
    }

    function isValidThumbnail(data) {
      let allowedFields = ['title', 'description', 'imageUrl', 'category', 'stats', 'createdAt'];
      let requiredFields = ['title', 'imageUrl', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description == null || (data.description is string && data.description.size() <= 1000))) &&
             data.imageUrl is string && data.imageUrl.size() >= 1 && data.imageUrl.size() <= 2097152 && // 2MB limit for base64
             data.createdAt is timestamp &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
             (!('stats' in data) || (data.stats is string && data.stats.size() <= 50));
    }

    function isValidBTS(data) {
      let allowedFields = ['title', 'videoTitle', 'description', 'layoutIdea', 'designWorkflow', 'caseStudy', 'clientFeedback', 'clientName', 'clientPhoto', 'whatsappChat', 'imageUrl', 'beforeImages', 'afterImages', 'createdAt'];
      let requiredFields = ['title', 'imageUrl', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.imageUrl is string && data.imageUrl.size() >= 1 && data.imageUrl.size() <= 2097152 &&
             (!('videoTitle' in data) || (data.videoTitle == null || (data.videoTitle is string && data.videoTitle.size() <= 200))) &&
             (!('description' in data) || (data.description == null || (data.description is string && data.description.size() <= 5000))) &&
             (!('layoutIdea' in data) || (data.layoutIdea == null || (data.layoutIdea is string && data.layoutIdea.size() <= 2000))) &&
             (!('designWorkflow' in data) || (data.designWorkflow == null || (data.designWorkflow is string && data.designWorkflow.size() <= 2000))) &&
             (!('caseStudy' in data) || (data.caseStudy == null || (data.caseStudy is string && data.caseStudy.size() <= 10000))) &&
             (!('clientFeedback' in data) || (data.clientFeedback == null || (data.clientFeedback is string && data.clientFeedback.size() <= 2000))) &&
             (!('clientName' in data) || (data.clientName == null || (data.clientName is string && data.clientName.size() <= 100))) &&
             (!('clientPhoto' in data) || (data.clientPhoto == null || (data.clientPhoto is string && data.clientPhoto.size() <= 1048576))) &&
             (!('whatsappChat' in data) || (data.whatsappChat == null || (data.whatsappChat is list && data.whatsappChat.size() <= 50))) &&
             (!('beforeImages' in data) || (data.beforeImages == null || (data.beforeImages is list && data.beforeImages.size() <= 5))) &&
             (!('afterImages' in data) || (data.afterImages == null || (data.afterImages is list && data.afterImages.size() <= 5))) &&
             data.createdAt is timestamp;
    }

    function isValidRandomPost(data) {
      let allowedFields = ['title', 'desc', 'image', 'rotate', 'y', 'createdAt'];
      let requiredFields = ['title', 'desc', 'image', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             data.desc is string && data.desc.size() >= 1 && data.desc.size() <= 500 &&
             data.image is string && data.image.size() >= 1 && data.image.size() <= 2097152 &&
             (!('rotate' in data) || data.rotate is number) &&
             (!('y' in data) || data.y is number) &&
             data.createdAt is timestamp;
    }

    function isValidWorkspaceImage(data) {
      let allowedFields = ['url', 'caption', 'createdAt'];
      let requiredFields = ['url', 'caption', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.url is string && data.url.size() >= 1 && data.url.size() <= 2097152 &&
             data.caption is string && data.caption.size() >= 1 && data.caption.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidHeroThumbnail(data) {
      let allowedFields = ['url', 'rotate', 'x', 'y', 'createdAt'];
      let requiredFields = ['url', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.url is string && data.url.size() >= 1 && data.url.size() <= 2097152 &&
             (!('rotate' in data) || data.rotate is number) &&
             (!('x' in data) || data.x is number) &&
             (!('y' in data) || data.y is number) &&
             data.createdAt is timestamp;
    }

    match /comments/{commentId} {
      // Allow public read for portfolio visibility
      allow read: if true;
      
      // Allow public create with strict validation
      allow create: if isValidComment(request.resource.data);
      
      // Deny update and delete for public users
      allow update, delete: if false;
    }

    match /thumbnails/{thumbnailId} {
      // Allow public read for portfolio visibility
      allow read: if true;
      
      // Only admin can create, update, or delete thumbnails
      allow create: if isAdmin() && isValidThumbnail(request.resource.data);
      allow update: if isAdmin() && isValidThumbnail(request.resource.data);
      allow delete: if isAdmin();
    }

    match /behind_the_scenes/{btsId} {
      // Allow public read
      allow read: if true;
      
      // Only admin can create, update, or delete BTS content
      allow create, update: if isAdmin() && isValidBTS(request.resource.data);
      allow delete: if isAdmin();
    }

    match /random_posts/{postId} {
      // Allow public read
      allow read: if true;
      
      // Only admin can create or delete random posts
      allow create: if isAdmin() && isValidRandomPost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /workspace_images/{imageId} {
      // Allow public read
      allow read: if true;
      
      // Only admin can create or delete workspace images
      allow create: if isAdmin() && isValidWorkspaceImage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /hero_thumbnails/{thumbnailId} {
      // Allow public read
      allow read: if true;
      
      // Only admin can create or delete hero thumbnails
      allow create: if isAdmin() && isValidHeroThumbnail(request.resource.data);
      allow delete: if isAdmin();
    }

    // Allow public read for connection testing
    match /test/connection {
      allow read: if true;
    }

    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
